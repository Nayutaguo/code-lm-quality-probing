# Codeflaws correctness preset. Scripts in scripts/codeflaws source this file by default.

MODEL_PATH="${MODEL_PATH:-/mnt/sda/yz/projects/models/llama-3.1-8b}"
CONCEPT_NAME="${CONCEPT_NAME:-codeflaws_correctness}"
POSITIVE_NAME="${POSITIVE_NAME:-correct}"
NEGATIVE_NAME="${NEGATIVE_NAME:-incorrect}"

# Generic pair schema produced by code/codeflaws/prepare_answer_pairs.py.
TASK_FIELD="${TASK_FIELD:-description}"
POSITIVE_FIELD="${POSITIVE_FIELD:-correct_code}"
NEGATIVE_FIELD="${NEGATIVE_FIELD:-incorrect_code}"
METADATA_FIELDS="${METADATA_FIELDS:-language dataset pair_id base_pair_id problem_id contest_id problem_index buggy_submission_id accepted_submission_id subject_dir incorrect_file correct_file defect_class verdict defect_tags repair_test_count heldout_test_count has_test_genprog has_test_valid split split_mode}"

RAW_DATA_DIR="${RAW_DATA_DIR:-data/Codeflaws/codeflaws}"
PROCESSED_DATA_DIR="${PROCESSED_DATA_DIR:-data/Codeflaws/processed}"
DATA_NAME="${DATA_NAME:-codeflaws_correctness_train}"
TRAIN_DATA_FILES="${TRAIN_DATA_FILES:-${PROCESSED_DATA_DIR}/codeflaws_correctness_train.jsonl}"
VAL_DATA_FILES="${VAL_DATA_FILES:-${PROCESSED_DATA_DIR}/codeflaws_correctness_val.jsonl}"
TEST_DATA_FILES="${TEST_DATA_FILES:-${PROCESSED_DATA_DIR}/codeflaws_correctness_test.jsonl}"

PREFERENCE_QUESTION="${PREFERENCE_QUESTION:-Which implementation is more likely to be correct and pass the tests?}"
ARTIFACT_ROOT="${ARTIFACT_ROOT:-artifacts/codeflaws}"

DTYPE="${DTYPE:-bfloat16}"
DEVICE_MAP="${DEVICE_MAP:-auto}"
MAX_LENGTH="${MAX_LENGTH:-}"
