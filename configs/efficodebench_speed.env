# EffiCodeBench speed/efficiency preset.

MODEL_PATH="${MODEL_PATH:-/mnt/sda/yz/projects/models/llama-3.1-8b}"
CONCEPT_NAME="${CONCEPT_NAME:-efficodebench_speed}"
POSITIVE_NAME="${POSITIVE_NAME:-fast}"
NEGATIVE_NAME="${NEGATIVE_NAME:-slow}"

# Converted JSONL field mapping:
#   description - generic runtime-efficiency comparison task text.
#   fast_code   - faster implementation.
#   slow_code   - slower implementation.
TASK_FIELD="${TASK_FIELD:-description}"
POSITIVE_FIELD="${POSITIVE_FIELD:-fast_code}"
NEGATIVE_FIELD="${NEGATIVE_FIELD:-slow_code}"
METADATA_FIELDS="${METADATA_FIELDS:-language pair_id base_pair_id problem_id split source_file source_row_index original_output original_direction speedup_ratio output_score fast_original_side slow_original_side}"

RAW_DATA_DIR="${RAW_DATA_DIR:-data/efficodebench/efficodebench-dataset}"
PROCESSED_DATA_DIR="${PROCESSED_DATA_DIR:-data/efficodebench/processed}"
TRAIN_DATA_FILES="${TRAIN_DATA_FILES:-${PROCESSED_DATA_DIR}/efficodebench_ab_train.jsonl}"
VAL_DATA_FILES="${VAL_DATA_FILES:-${PROCESSED_DATA_DIR}/efficodebench_ab_val.jsonl}"
TEST_DATA_FILES="${TEST_DATA_FILES:-${PROCESSED_DATA_DIR}/efficodebench_ab_test.jsonl}"

# Keep EffiCodeBench outputs separate from the existing SafeCoder safety artifacts.
ARTIFACT_ROOT="${ARTIFACT_ROOT:-artifacts/efficodebench}"

PREFERENCE_QUESTION="${PREFERENCE_QUESTION:-Which implementation is faster at runtime and should be preferred?}"
BACKEND="${BACKEND:-hooks}"
DTYPE="${DTYPE:-bfloat16}"
DEVICE_MAP="${DEVICE_MAP:-auto}"
MAX_LENGTH="${MAX_LENGTH:-4096}"
OVERFLOW_POLICY="${OVERFLOW_POLICY:-drop}"
