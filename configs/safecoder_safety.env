# SafeCoder safety preset. Scripts source this file by default.

MODEL_PATH="${MODEL_PATH:-/mnt/sda/yz/projects/models/llama-3.1-8b}"
CONCEPT_NAME="${CONCEPT_NAME:-safety}"
POSITIVE_NAME="${POSITIVE_NAME:-safe}"
NEGATIVE_NAME="${NEGATIVE_NAME:-unsafe}"

# SafeCoder JSONL field mapping:
#   description     - task text shared by before/after implementations.
#   func_src_after  - repaired/safe implementation.
#   func_src_before - original/unsafe implementation.
TASK_FIELD="${TASK_FIELD:-description}"
POSITIVE_FIELD="${POSITIVE_FIELD:-func_src_after}"
NEGATIVE_FIELD="${NEGATIVE_FIELD:-func_src_before}"
# Metadata fields are copied into reports only; they are not used to compute vectors.
METADATA_FIELDS="${METADATA_FIELDS:-vul_type file_name func_name}"

# DATA_NAME is part of artifact filenames. Change it when changing dataset shards,
# field mapping, or pooling so artifacts do not silently collide.
DATA_NAME="${DATA_NAME:-sec_desc_sec_new_desc}"
TRAIN_DATA_FILES="${TRAIN_DATA_FILES:-data/SafeCoder/data_train_val/train/sec-desc.jsonl data/SafeCoder/data_train_val/train/sec-new-desc.jsonl}"
VAL_DATA_FILES="${VAL_DATA_FILES:-data/SafeCoder/data_train_val/val/sec-desc.jsonl data/SafeCoder/data_train_val/val/sec-new-desc.jsonl}"

# BACKEND choices:
#   hooks  - lower memory, pool/steer block outputs by forward hooks.
#   native - use output_hidden_states=True, easier to debug but more memory.
BACKEND="${BACKEND:-hooks}"
# POOLING choices:
#   mean_code_span, first_code_token, last_code_token, changed_mean, all_tokens_mean.
POOLING="${POOLING:-mean_code_span}"
DTYPE="${DTYPE:-bfloat16}"
DEVICE_MAP="${DEVICE_MAP:-auto}"
